<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="cron_shopflow_sync_products" model="ir.cron">
            <field name="name">ShopFlow: Sync Products to Shopify</field>
            <field name="model_id" ref="model_shopify_sync"/>
            <field name="state">code</field>
            <field name="code">model.sync_products_to_shopify()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

        <record id="cron_shopflow_pull_orders" model="ir.cron">
            <field name="name">ShopFlow: Pull Orders from Shopify</field>
            <field name="model_id" ref="model_shopify_sync"/>
            <field name="state">code</field>
            <field name="code">model.sync_orders_from_shopify()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

        <record id="cron_shopflow_retry_failed_syncs" model="ir.cron">
            <field name="name">ShopFlow: Retry Failed Syncs</field>
            <field name="model_id" ref="model_shopify_sync"/>
            <field name="state">code</field>
            <field name="code">model.retry_failed_syncs()</field>
            <field name="interval_number">6</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

        <record id="cron_shopflow_pull_customers" model="ir.cron">
            <field name="name">ShopFlow: Pull Customers from Shopify</field>
            <field name="model_id" ref="model_shopify_sync"/>
            <field name="state">code</field>
            <field name="code">model.sync_customers_from_shopify()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>