<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_product_template_shopflow_tree" model="ir.ui.view">
            <field name="name">product.template.shopflow.tree</field>
            <field name="model">product.template</field>
            <field name="priority">5</field>
            <field name="arch" type="xml">
                <tree>
                    <header>
                        <button name="action_open_sync_wizard"
                                type="object"
                                string="Sync Products"
                                class="btn-primary"/>
                    </header>
                    <field name="name"/>
                    <field name="default_code"/>
                    <field name="list_price"/>
                    <field name="shopify_product_id"/>
                    <field name="shopify_synced"/>
                    <field name="shopify_synced_on"/>
                    <field name="tags"/>
                </tree>
            </field>
        </record>

        <record id="view_product_template_shopflow_form" model="ir.ui.view">
            <field name="name">product.template.shopflow.form</field>
            <field name="model">product.template</field>
            <field name="priority">5</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_export_to_shopify"
                                type="object"
                                string="Export to Shopify"
                                class="btn-primary"/>
                        <button name="action_open_sync_wizard"
                                type="object"
                                string="Sync Products"
                                class="btn-secondary"/>
                    </header>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="default_code"/>
                            <field name="list_price"/>
                            <field name="shopify_product_id"/>
                            <field name="shopify_synced"/>
                            <field name="shopify_synced_on" readonly="1"/>
                            <field name="tags"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_shopflow_catalog" model="ir.actions.act_window">
            <field name="name">Catalog</field>
            <field name="res_model">product.template</field>
            <field name="view_mode">tree,form</field>
            <field name="views" eval="[(ref('view_product_template_shopflow_tree'), 'tree'), (ref('view_product_template_shopflow_form'), 'form')]"/>
        </record>
    </data>
</odoo>

