<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_res_partner_shopflow_tree" model="ir.ui.view">
            <field name="name">res.partner.shopflow.tree</field>
            <field name="model">res.partner</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="email"/>
                    <field name="shopflow_customer_id"/>
                    <field name="loyalty_points"/>
                    <field name="registration_date"/>
                </tree>
            </field>
        </record>

        <record id="view_res_partner_shopflow_form" model="ir.ui.view">
            <field name="name">res.partner.shopflow.form</field>
            <field name="model">res.partner</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="email"/>
                            <field name="shopflow_customer_id"/>
                            <field name="loyalty_points"/>
                            <field name="registration_date"/>
                            <field name="shopflow_address_type"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_shopflow_customers" model="ir.actions.act_window">
            <field name="name">ShopFlow Customers</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('shopflow_customer_id', '!=', False)]</field>
        </record>

        <menuitem id="menu_shopflow_customers_action"
                  name="Customers"
                  parent="menu_shopflow_customers"
                  action="action_shopflow_customers"
                  sequence="10"/>
    </data>
</odoo>

