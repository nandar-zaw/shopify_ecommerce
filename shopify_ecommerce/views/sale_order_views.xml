<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_sale_order_form_shopflow" model="ir.ui.view">
            <field name="name">sale.order.form.shopflow</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet" position="inside">
                    <group string="ShopFlow">
                        <field name="shopify_order_id"/>
                        <field name="cart_id"/>
                        <field name="shipping_cost"/>
                    </group>
                </xpath>
            </field>
        </record>

        <record id="view_sale_order_shopflow_tree" model="ir.ui.view">
            <field name="name">sale.order.shopflow.tree</field>
            <field name="model">sale.order</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="date_order"/>
                    <field name="shopify_order_id"/>
                    <field name="cart_id"/>
                    <field name="state"/>
                    <field name="amount_total"/>
                </tree>
            </field>
        </record>

        <record id="action_shopflow_orders" model="ir.actions.act_window">
            <field name="name">Orders</field>
            <field name="res_model">sale.order</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">['|', ('shopify_order_id', '!=', False), ('cart_id', '!=', False)]</field>
        </record>

        <menuitem id="menu_shopflow_orders_action"
                  name="Sales Orders"
                  parent="menu_shopflow_orders"
                  action="action_shopflow_orders"
                  sequence="10"/>
    </data>
</odoo>

