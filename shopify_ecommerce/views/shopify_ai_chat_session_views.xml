<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_shopify_ai_chat_session_tree" model="ir.ui.view">
            <field name="name">shopify.ai.chat.session.tree</field>
            <field name="model">shopify.ai.chat.session</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="customer_id"/>
                    <field name="start_time"/>
                    <field name="end_time"/>
                    <field name="resolved"/>
                    <field name="escalated"/>
                    <field name="agent_id"/>
                </tree>
            </field>
        </record>

        <record id="view_shopify_ai_chat_session_form" model="ir.ui.view">
            <field name="name">shopify.ai.chat.session.form</field>
            <field name="model">shopify.ai.chat.session</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="customer_id"/>
                            <field name="start_time"/>
                            <field name="end_time"/>
                            <field name="resolved"/>
                            <field name="escalated"/>
                            <field name="satisfaction_rating"/>
                            <field name="agent_id"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_shopify_ai_chat_session" model="ir.actions.act_window">
            <field name="name">Chat Sessions</field>
            <field name="res_model">shopify.ai.chat.session</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem id="menu_shopflow_ai_chat_session"
                  name="Chat Sessions"
                  parent="menu_shopflow_ai"
                  action="action_shopify_ai_chat_session"
                  sequence="30"/>
    </data>
</odoo>

